    "luuKnockoutRules": {
      "description": "Rules applied when a friendly Luu is knocked out",
      "steps": [
        "1. Apply overflow damage to next Luu in queue",
        "2. Discard all persistent and untilTriggered action cards attached to knocked-out Luu without triggering effects",
        "3. Discard any global effects that reference this Luu (e.g. Shell Bond checking adjacency)",
        "4. Fire onLuuKnockedOut trigger for any active global effects (e.g. Last Lesson)",
        "5. Remove Luu from queue, shift remaining Luu forward",
        "7. Add knocked-out Luu card to discard pile",
        "8. Check lose condition: if all Luu defeated, game over"
      ]
    },
